# LearnFlow Environment Configuration
# Copy this file to .env and fill in your values

# ==================== Application ====================
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ==================== Authentication ====================
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==================== Cerebras AI ====================
CEREBRAS_API_KEY=your-cerebras-api-key-here
CEREBRAS_MODEL=llama3.1-70b

# ==================== Database ====================
DATABASE_URL=postgresql://user:password@localhost:5432/learnflow
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ==================== Kafka ====================
KAFKA_BROKERS=localhost:9092
KAFKA_CONSUMER_GROUP=learnflow-services

# ==================== Dapr ====================
DAPR_HTTP_PORT=3500
DAPR_GRPC_PORT=50001
DAPR_PUBSUB_NAME=learnflow-pubsub

# ==================== Service URLs ====================
TRIAGE_AGENT_URL=http://localhost:8001
CONCEPTS_AGENT_URL=http://localhost:8002
DEBUG_AGENT_URL=http://localhost:8003
EXERCISE_AGENT_URL=http://localhost:8004
CODE_REVIEW_AGENT_URL=http://localhost:8006
PROGRESS_AGENT_URL=http://localhost:8005

# ==================== Redis (for Dapr statestore) ====================
REDIS_URL=redis://localhost:6379

# ==================== Frontend ====================
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
